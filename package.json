{
  "name": "books1",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-books1": "cds watch --open books1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy books1 --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "[development]": {
          "strategy": "mocked",
          "users": {
            "suman": {
              "password": "welcome1",
              "roles": [
                "Admin"
              ]
            },
            "Kids": {
              "password": "welcome2",
              "roles": [
                "Kids"
              ],
              "userAttributes": {
                "bookAgeGroup": [
                  "KIDS"
                ]
              }
            },
            "Adult": {
              "password": "welcome3",
              "roles": [
                "Adult"
              ],
              "userAttributes": {
                "bookAgeGroup": [
                  "ADULT"
                ]
              }
            }
          }
        }
      },
      "[production]": {
        "db": "hana",
        "strategy": "JWT",
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/books1"
  ]
}
